# Port the server listens on. Most hosts (Fly, Render, Railway) inject this themselves.
PORT=3000

# Host bind address. 0.0.0.0 lets the host route traffic in.
HOST=0.0.0.0

# Git ref of Motion-Creative/runneth-apps to read curated metadata from.
# Leave as 'main' for production. Useful to point at a branch for staging or QA.
RUNNETH_APPS_REF=main

# Fastify log level. info | warn | error | debug
LOG_LEVEL=info
