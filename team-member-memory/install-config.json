{
  "schema": "1.0",
  "id": "team-member-memory",
  "version": "1.0.0",
  "description": "Runneth gets to know each person it works with — their goals, preferences, and working style — and adapts to them over time.",
  "customize": [
    {
      "token": "{{TEAM_MAP_PATH}}",
      "description": "Path to the JSON file that maps user emails to team member files.",
      "required": false,
      "fallback": "/agent/brain/team/user-map.json"
    },
    {
      "token": "{{TEAM_DIR}}",
      "description": "Directory where individual team member markdown files are stored.",
      "required": false,
      "fallback": "/agent/brain/team/"
    },
    {
      "token": "{{TEAM_MEMBER_TEMPLATE_PATH}}",
      "description": "Path to the blank template used when creating a new team member file.",
      "required": false,
      "fallback": "/agent/brain/team/TEMPLATE.md"
    },
    {
      "token": "{{CONVERSATIONS_PATH}}",
      "description": "Directory where per-conversation one-pager files are stored.",
      "required": false,
      "fallback": "/agent/brain/conversations/"
    },
    {
      "token": "{{ONEPAGER_TEMPLATE_PATH}}",
      "description": "Path to the one-pager template used when creating a new conversation file.",
      "required": false,
      "fallback": "/agent/brain/conversations/TEMPLATE.md"
    }
  ],
  "installs": [
    {
      "file": "user-map.json",
      "dest": "{{TEAM_MAP_PATH}}",
      "if-not-exists": true,
      "merge-strategy": "preserve-keys"
    },
    {
      "file": "team-member-template.md",
      "dest": "{{TEAM_MEMBER_TEMPLATE_PATH}}",
      "if-not-exists": true
    },
    {
      "file": "onepager-template.md",
      "dest": "{{ONEPAGER_TEMPLATE_PATH}}",
      "if-not-exists": true
    },
    {
      "file": "behavior-snippet.md",
      "dest": "user-md",
      "insert-after": "## System routines",
      "insert-fallback": "append"
    }
  ],
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2026-05-06",
      "type": "major",
      "notes": "Initial release. Email-based user identification, team file per person with template, conversation one-pager system."
    }
  ]
}
