{
  "schemaVersion": 1,
  "id": "runneth-default",
  "name": "Runneth Default",
  "version": "0.2.0",
  "description": "Installs baseline Runneth creative strategy skills and a small customer-owned integration setup surface.",
  "updatePolicy": "auto",
  "resources": [
    {
      "id": "analyzing",
      "type": "directory",
      "sourcePath": "skills/analyzing",
      "target": {
        "root": "agent_skills",
        "path": "analyzing"
      },
      "executablePaths": []
    },
    {
      "id": "briefing",
      "type": "directory",
      "sourcePath": "skills/briefing",
      "target": {
        "root": "agent_skills",
        "path": "briefing"
      },
      "executablePaths": []
    },
    {
      "id": "creative-generation",
      "type": "directory",
      "sourcePath": "skills/creative-generation",
      "target": {
        "root": "agent_skills",
        "path": "creative-generation"
      },
      "executablePaths": []
    },
    {
      "id": "core-creative-skills",
      "type": "package_instruction",
      "sourcePath": "instructions/core-creative-skills.md"
    },
    {
      "id": "integration-setup",
      "type": "package_instruction",
      "sourcePath": "instructions/integration-setup.md"
    },
    {
      "id": "integration-notes-index",
      "type": "seed_file",
      "sourcePath": "brain/integrations/index.md",
      "target": {
        "root": "agent_brain",
        "path": "integrations/index.md"
      }
    },
    {
      "id": "integration-map-template",
      "type": "seed_file",
      "sourcePath": "brain/integrations/_templates/integration-map.md",
      "target": {
        "root": "agent_brain",
        "path": "integrations/_templates/integration-map.md"
      }
    },
    {
      "id": "slack-integration-notes",
      "type": "seed_file",
      "sourcePath": "brain/integrations/slack.md",
      "target": {
        "root": "agent_brain",
        "path": "integrations/slack.md"
      }
    }
  ]
}
