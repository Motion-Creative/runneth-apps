{
  "schemaVersion": 1,
  "id": "runneth-default",
  "name": "Runneth Default",
  "version": "0.3.0",
  "description": "Installs baseline Runneth creative strategy skills and customer-owned integration setup templates.",
  "updatePolicy": "auto",
  "resources": [
    {
      "id": "analyzing",
      "type": "directory",
      "sourcePath": "skills/analyzing",
      "target": {
        "root": "agent_skills",
        "path": "analyzing"
      },
      "executablePaths": []
    },
    {
      "id": "briefing",
      "type": "directory",
      "sourcePath": "skills/briefing",
      "target": {
        "root": "agent_skills",
        "path": "briefing"
      },
      "executablePaths": []
    },
    {
      "id": "creative-generation",
